      "items": {
        "appPurpose": {
          "question": "월드 리퍼블릭이란 무엇인가요?",
          "answer": "월드 리퍼블릭은 인류의 가장 시급한 글로벌 과제 해결을 위해 헌신하는 개방적이고 민주적인 조직입니다. AI 위험, 기후 변화, 생물안보와 같이 글로벌 차원에서만 효과적으로 다룰 수 있는 문제들에 대한 집단적 의사결정 프레임워크를 제공합니다."
        },
        "basicIncome": {
          "question": "기본소득이란 무엇인가요?",
          "answer": "저희의 기본소득은 월드 리퍼블릭의 모든 시민에게 제공되는 0.0025 WDD(월드 드라크마)의 일일 보조금입니다. 실시간으로 누적되며 앱을 통해 언제든지 청구할 수 있습니다."
        },
        "basicIncomePlus": {
          "question": "기본소득 플러스는 어떻게 활성화하나요?",
          "answer": "기본소득 플러스는 하루 추가 0.0475 WDD를 제공하며 Orb 인증을 받은 사용자만 이용할 수 있습니다. 기본소득을 활성화한 후 수입 페이지에서 기본소득 플러스 활성화 옵션을 확인할 수 있습니다."
        },
        "savings": {
          "question": "저축 계좌는 어떻게 작동하나요?",
          "answer": "저축 계좌에 WDD 토큰을 예치하면 연 69%의 이자를 받을 수 있습니다. 발생한 이자를 지속적으로 재투자하면 연간 실효 수익률이 100%에 가까워져 시간이 지날수록 WDD가 최대한 증가합니다. 이자는 계속 누적되며 언제든지 출금하거나 재투자할 수 있습니다."
        },
        "referralCodes": {
          "question": "추천 코드는 어떻게 작동하나요?",
          "answer": "월드 리퍼블릭 시민으로서 추천 프로그램을 통해 보상을 받을 수 있습니다. 고유한 추천 링크를 친구들과 공유하면, 우리 웹앱에 가입하고 라이브니스 검사를 완료한 사람 한 명당 10 WDD를 받게 됩니다."
        },
        "drachmaValue": {
          "question": "드라크마는 어디서 가치를 얻나요?",
          "answer": "드라크마는 월드 리퍼블릭의 공식 화폐로서 가치를 얻습니다. 우리의 민주적 글로벌 거버넌스 플랫폼이 성장함에 따라 WDD는 세계 경제에서 중요한 교환 수단이 될 잠재력이 있으며, 궁극적으로 기술 발전과 글로벌 자원의 혜택을 공평하게 분배하는 데 역할을 할 수 있습니다."
        },
