    "faq": {
      "title": "常见问题",
      "items": {
        "appPurpose": {
          "question": "什么是世界共和国？",
          "answer": "世界共和国是一个开放、民主的组织，致力于解决人类最紧迫的全球性挑战。它为集体决策提供框架，解决只能在全球范围内有效应对的问题，如人工智能风险、气候变化或生物安全。"
        },
        "basicIncome": {
          "question": "什么是基本收入？",
          "answer": "我们的基本收入是每天向所有世界共和国公民提供0.0025 WDD（世界德拉克马）的补贴。它实时累积，可以随时通过应用程序领取。"
        },
        "basicIncomePlus": {
          "question": "如何激活基本收入增强版？",
          "answer": "基本收入增强版每天提供额外0.0475 WDD，仅向Orb验证用户开放。激活基本收入后，您将在赚取页面看到激活基本收入增强版的选项。"
        },
        "savings": {
          "question": "储蓄账户如何运作？",
          "answer": "储蓄账户允许您存入WDD代币并获得69%的年化利息。通过持续再投资所得利息，用户可以实现接近100%的年度有效回报，随时间最大化WDD增长。利息持续累积，可以随时提取或再投资。"
        },
        "referralCodes": {
          "question": "推荐码如何工作？",
          "answer": "作为世界共和国公民，您可以通过我们的推荐计划获得奖励。将您的专属推荐链接分享给朋友，每有一人加入我们的网页应用并完成活体检测，您将获得 10 WDD。"
        },
        "drachmaValue": {
          "question": "德拉克马从何处获得价值？",
          "answer": "德拉克马作为世界共和国的官方货币获得其价值。随着我们的民主全球治理平台发展，WDD有潜力成为世界经济中重要的交换媒介，并最终可能在技术进步和全球资源的公平分配中发挥作用。"
        },
        "topWallets": {
          "question": "谁控制着最大的账户？",
          "answer": "三个最大的账户是<a href='https://worldscan.org/address/0xa3C2c8CE6Be1C55401b5F1EfB6112A86F6374429' target='_blank' rel='noopener noreferrer' class='underline'>世界共和国财政部</a>、<a href='https://worldscan.org/address/0x02c3B99D986ef1612bAC63d4004fa79714D00012' target='_blank' rel='noopener noreferrer' class='underline'>基本收入基金</a>和<a href='https://worldscan.org/address/0x52DFEe61180A0BCEBe007E5a9Cfd466948aCCA46' target='_blank' rel='noopener noreferrer' class='underline'>基本收入附加基金</a>。这些账户目前由项目创始人管理，以确保稳定，同时我们逐步将控制权移交给社区。其他关键地址包括<a href='https://worldscan.org/address/0x234302Db10A54BDc11094A8Ef816B0Eaa5FCE3f7' target='_blank' rel='noopener noreferrer' class='underline'>储蓄账户合约</a>、<a href='https://worldscan.org/address/0x372dCA057682994568be074E75a03Ced3dD9E60d' target='_blank' rel='noopener noreferrer' class='underline'>推荐奖励分发器</a>和流动性池：<a href='https://worldscan.org/address/0xaaEF72194E42aF8f641e90c3e48a7F01e9547097' target='_blank' rel='noopener noreferrer' class='underline'>WLD/WDD</a>、<a href='https://worldscan.org/address/0x24Cda46262Ee6b777416997c52FE140A0B3f6FeA' target='_blank' rel='noopener noreferrer' class='underline'>USDC/WDD</a>和<a href='https://worldscan.org/address/0x3226d525Bb0EA2346D512215ca8df7d81801786E' target='_blank' rel='noopener noreferrer' class='underline'>ETH/WDD</a>。"
        },
        "voteRequirements": {
          "question": "我如何参与治理？",
          "answer": "您可以通过加入或创建一个政党来参与。虽然目前的投票是指示性的，但政党是我们治理模式的基础。随着政党的专业化，它们将为民主控制解锁越来越重要的领域，让您在我们的集体决策中拥有发言权。"
        }
